# Image to deploy
IMAGE_NAME=<registry>/<your-org>/msr-order-management
TAG=<image-tag>
DEPLOYMENT_NAME=msr-order-management
DOCKER_PORT_NUMBER=<local-port>

# PostgreSQL
DB_SERVER_NAME=postgres
DB_PORT=5432
DB_DATABASE_NAME=<database-name>
DB_USERNAME=<db-username>
DB_PASSWORD=<db-password>

# JDBC pool 
POOL_JDBC_URL="jdbc:wm:postgresql://postgres:5432;DatabaseName=postgres"
POOL_DB_USERNAME=<db-username>
POOL_DB_PASSWORD=<db-password>

# Universal Messaging JNDI
JNDI_URL=nsp://umserver:9000

# MSR users
ADMIN_PASSWORD=<admin-password>
TESTER_PASSWORD=<tester-password>

# Keystores and truststores
API_KEYSTORE_PASSWORD=<api-keystore-password>