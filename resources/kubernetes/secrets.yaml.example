apiVersion: v1
kind: Secret
metadata:
  name: msr-order-management
type: Opaque
stringData:
  ADMIN_PASSWORD: <admin-password>
  TESTER_PASSWORD: <tester-password>
  DB_SERVER_NAME: <postgres-host>.svc.cluster.local
  DB_PORT: "5432"
  DB_DATABASE_NAME: <database-name>
  DB_USERNAME: <db-username>
  DB_PASSWORD: <db-password>
  JNDI_URL: nsps://<um-host>.svc.cluster.local:<um-port>
  UM_TRUSTSTORE_PASSWORD: <truststore-password>

---

apiVersion: v1
kind: Secret
metadata:
  name: um-truststore
type: Opaque
data:
  um-truststore.jks: <base64-encoded-truststore>

---

# Secret for the image pull (create it via kubectl) :
# kubectl create secret docker-registry orders-regcred \
#   --docker-server=${GH_CR_SERVER} \
#   --docker-username=${GH_CR_USERNAME} \
#   --docker-password=${GH_CR_PASSWORD}
