<?xml version="1.0" encoding="UTF-8"?>

<Values version="2.0">
  <record name="listeners" javaclass="com.wm.util.Values">
    <record name="FilePollingListener:files/incoming" javaclass="com.wm.util.Values">
      <value name="port">files/incoming</value>
      <value name="protocol">FilePolling</value>
      <value name="pkg">demoOrderManagement</value>
      <value name="enabled">true</value>
      <value name="key">FilePollingListener:files/incoming</value>
      <value name="portAlias">orderfile_polling</value>
      <value name="portDescription">orderfile_polling</value>
      <value name="factoryKey">webMethods/FilePolling</value>
      <value name="configURL">/WmFlatFile/configFilePolling.dsp</value>
      <value name="provider">webMethods</value>
      <value name="monitorDir">files/incoming</value>
      <value name="workDir">files/work</value>
      <value name="completionDir">files/processed</value>
      <value name="errorDir">files/error</value>
      <value name="recursive">no</value>
      <value name="clusterEnabled">no</value>
      <value name="cleanupAtStartup">yes</value>
      <value name="runUser">Administrator</value>
      <value name="processingService">demoOrderManagement.services:receiveOrderFile</value>
      <value name="filePollingInterval">60</value>
      <value name="logMinMessage">no</value>
      <value name="NFSDirectories">yes</value>
      <value name="cleanUpFileAge">7</value>
      <value name="cleanUpInterval">24</value>
      <value name="maxThreads">5</value>
      <value name="maxFilesPerCycle">-1</value>
      <value name="lockFileExtension">.lock</value>
    </record>
  </record>
  <record name="access" javaclass="com.wm.util.Values">
    <record name="FilePollingListener:files/incoming" javaclass="com.wm.util.Values">
      <null name="home"/>
      <value name="default">include</value>
      <record name="nodes" javaclass="com.wm.util.StringSet">
        <list name="elements">
        </list>
      </record>
      <value name="key">FilePollingListener:files/incoming</value>
    </record>
  </record>
</Values>
